--// Утилита: создание переключателя (Toggle)
local function createToggle(parent, labelText, position)
	local container = Instance.new("Frame")
	container.Name = labelText .. "Container"
	container.Size = UDim2.new(1, -20, 0, 50)
	container.Position = position
	container.BackgroundTransparency = 1
	container.Parent = parent

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(0.65, 0, 1, 0)
	label.BackgroundTransparency = 1
	label.Text = labelText
	label.TextColor3 = CONFIG.SubTextColor
	label.Font = Enum.Font.Gotham
	label.TextSize = 14
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.TextTruncate = Enum.TextTruncate.AtEnd
	label.Parent = container

	local button = Instance.new("TextButton")
	button.Name = "ToggleButton"
	button.Size = UDim2.new(0, 60, 0, 28)
	button.Position = UDim2.new(1, -70, 0.5, -14)
	button.BackgroundColor3 = CONFIG.ToggleOff
	button.Text = "OFF"
	button.TextColor3 = CONFIG.TextColor
	button.Font = Enum.Font.GothamBold
	button.TextSize = 12
	button.AutoButtonColor = true
	button.Parent = container

	local buttonCorner = Instance.new("UICorner")
	buttonCorner.CornerRadius = UDim.new(0, 14)
	buttonCorner.Parent = button

	local state = false

	local function updateVisual()
		if state then
			button.BackgroundColor3 = CONFIG.ToggleOn
			button.Text = "ON"
		else
			button.BackgroundColor3 = CONFIG.ToggleOff
			button.Text = "OFF"
		end
	end

	return container, button, function() return state end, function(newState)
		state = newState
		updateVisual()
	end
end

--// Утилита: Drag (перетаскивание)
local function makeDraggable(frame, handle)
	local dragging = false
	local dragInput = nil
	local dragStart = nil
	local startPos = nil

	handle.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = frame.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
					dragInput = nil
				end
			end)
		end
	end)

	handle.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if input == dragInput and dragging then
			local delta = input.Position - dragStart
			frame.Position = UDim2.new(
				startPos.X.Scale,
				startPos.X.Offset + delta.X,
				startPos.Y.Scale,
				startPos.Y.Offset + delta.Y
			)
		end
	end)
end

--// Система вкладок
local tabs = {}
local tabContents = {}
local tabNames = {"Управление", "Телепорты", "Визуальные эффекты"}

for i, tabName in ipairs(tabNames) do
	local tabButton = Instance.new("TextButton")
	tabButton.Name = tabName .. "Tab"
	tabButton.Size = UDim2.new(1, -10, 0, 34)
	tabButton.Position = UDim2.new(0, 5, 0, 10 + (i - 1) * 44)
	tabButton.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
	tabButton.Text = tabName
	tabButton.TextColor3 = CONFIG.SubTextColor
	tabButton.Font = Enum.Font.Gotham
	tabButton.TextSize = 13
	tabButton.Parent = navFrame

	local tabBtnCorner = Instance.new("UICorner")
	tabBtnCorner.CornerRadius = UDim.new(0, 6)
	tabBtnCorner.Parent = tabButton

	local content = Instance.new("Frame")
	content.Name = tabName .. "Content"
	content.Size = UDim2.new(1, 0, 1, 0)
	content.BackgroundTransparency = 1
	content.Visible = (i == 1)
	content.Parent = contentFrame

	tabs[tabName] = tabButton
	tabContents[tabName] = content
end

local function switchTab(activeName)
	for name, content in pairs(tabContents) do
		local isActive = (name == activeName)
		content.Visible = isActive
		tabs[name].BackgroundColor3 = isActive and Color3.fromRGB(60, 60, 80) or Color3.fromRGB(40, 40, 50)
		tabs[name].TextColor3 = isActive and CONFIG.TextColor or CONFIG.SubTextColor
	end
end

for name, btn in pairs(tabs) do
	btn.MouseButton1Click:Connect(function()
		switchTab(name)
	end)
end

--// ============================================
--// ВКЛАДКА 1: УПРАВЛЕНИЕ
--// ============================================
local managementContent = tabContents["Управление"]

local speedContainer, speedBtn, getSpeedState, setSpeedState = createToggle(
	managementContent,
	"Скорость бега (45)",
	UDim2.new(0, 10, 0, 15)
)

local currentHumanoid = nil
local function onCharacterAdded(character)
	currentHumanoid = character:WaitForChild("Humanoid", 5)
end

if player.Character then
	onCharacterAdded(player.Character)
end
player.CharacterAdded:Connect(onCharacterAdded)

speedBtn.MouseButton1Click:Connect(function()
	local newState = not getSpeedState()
	setSpeedState(newState)
	local success, err = pcall(function()
		if newState and currentHumanoid then
			currentHumanoid.WalkSpeed = 45
		elseif not newState and currentHumanoid then
			currentHumanoid.WalkSpeed = 16
		end
	end)
	if not success then
		warn("Speed toggle error: " .. tostring(err))
	end
end)

RunService.Heartbeat:Connect(function()
	local success = pcall(function()
		if getSpeedState() and currentHumanoid then
			if currentHumanoid.WalkSpeed ~= 45 then
				currentHumanoid.WalkSpeed = 45
			end
		elseif not getSpeedState() and currentHumanoid then
			if currentHumanoid.WalkSpeed == 45 then
				currentHumanoid.WalkSpeed = 16
			end
		end
	end)
	if not success then
		-- Игнорируем ошибки кадра, чтобы не спамить консоль
	end
end)

