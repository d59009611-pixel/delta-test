    MainFrameSize = UDim2.new(0, 450, 0, 300),
    MainFramePosition = UDim2.new(0.5, -225, 0.5, -150),
    BackgroundColor = Color3.fromRGB(10, 10, 15),
    NeonPurple = Color3.fromRGB(180, 0, 255),
    TextColor = Color3.fromRGB(255, 255, 255),
    SecondaryText = Color3.fromRGB(180, 180, 180),
    ButtonColor = Color3.fromRGB(20, 20, 30),
    ButtonHover = Color3.fromRGB(30, 30, 45),
    TabHeight = 40,
    ColumnWidth = 210,
    ToggleSize = 40
}

-- ═══════════════════════════════════════════════════════════════════════
-- STATE VARIABLES — All Toggles, Values, States
-- ═══════════════════════════════════════════════════════════════════════

local State = {
    -- Tab 1: Main Farm
    WeaponSelect = "Melee",
    FarmMethod = "Level Quest",
    AutoFarmEnabled = false,
    TweenSpeed = 200,
    BringRadius = 50,
    BypassTeleport = false,
    AutoClickerRunning = false,
    TargetMob = nil,
    CurrentQuestMob = nil,
    CurrentQuestNpc = nil,
    AutoFarmConnection = nil,
    AutoClickConnection = nil,

    -- Tab 1: WalkSpeed
    WalkSpeed = 16,
    WalkSpeedConnection = nil,

    -- Tab 2: Stats & Teleport
    AutoMelee = false,
    AutoDefense = false,
    AutoSword = false,
    SelectedIsland = "Starter",
    TeleportCooldown = false,
    AutoStatConnection = nil,

    -- Tab 3: Visuals & ESP
    PlayerESP = false,
    LegendaryTracker = false,
    DevilFruitESP = false,
    HakiBerryESP = false,
    ChestESP = false,
    ESPConnections = {},
    ESPObjects = {},
    TracerLines = {},

    -- Tab 4: Shop & Settings
    AutoBuyShop = false,
    FruitSniper = false,
    AutoRaid = false,
    ScriptDestroyed = false
}

-- ═══════════════════════════════════════════════════════════════════════
-- UTILITY FUNCTIONS
-- ═══════════════════════════════════════════════════════════════════════

local function CreateInstance(instanceType, properties)
    local instance = Instance.new(instanceType)
    for property, value in pairs(properties) do
        instance[property] = value
    end
    return instance
end

local function CreateUIStroke(color, thickness, transparency)
    return CreateInstance("UIStroke", {
        Color = color,
        Thickness = thickness or 2,
        Transparency = transparency or 0
    })
end

local function CreateTextLabel(size, position, text, textColor, fontSize, parent)
    local label = CreateInstance("TextLabel", {
        Size = size,
        Position = position,
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = textColor,
        TextSize = fontSize,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Center,
        TextYAlignment = Enum.TextYAlignment.Center,
        Parent = parent
    })
    return label
end

local function CreateButton(size, position, backgroundColor, parent)
    local button = CreateInstance("TextButton", {
        Size = size,
        Position = position,
        BackgroundColor3 = backgroundColor,
        Text = "",
        AutoButtonColor = false,
        Parent = parent
    })
    return button
end

local function TweenObject(instance, properties, duration, style, direction)
    local tweenInfo = TweenInfo.new(
        duration or 0.3,
        style or Enum.EasingStyle.Quad,
        direction or Enum.EasingDirection.Out
    )
    local tween = TweenService:Create(instance, tweenInfo, properties)
    tween:Play()
    return tween
end

local function GetCharacter()
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        return char
    end
    return nil
end

local function GetRootPart()
    local char = GetCharacter()
    if char then
        return char:FindFirstChild("HumanoidRootPart")
    end
    return nil
end

local function GetHumanoid()
    local char = GetCharacter()
    if char then
        return char:FindFirstChildOfClass("Humanoid")
    end
    return nil
end

local function SafeTweenTo(targetCFrame, speed)
    local root = GetRootPart()
    if not root then return end
    local distance = (targetCFrame.Position - root.Position).Magnitude
    local duration = distance / (speed or State.TweenSpeed)
    local tweenInfo = TweenInfo.new(
        duration,
        Enum.EasingStyle.Linear,
        Enum.EasingDirection.Out
    )
    local goal = {CFrame = targetCFrame}
    local tween = TweenService:Create(root, tweenInfo, goal)
    tween:Play()
    return tween
end

local function DistanceFromCharacter(position)
    local root = GetRootPart()
    if not root then return math.huge end
    return (position - root.Position).Magnitude
end

local function GetAllPlayers()
    local playerList = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            table.insert(playerList, player)
        end
    end
    return playerList
end

local function GetClosestMob(radius)
    local root = GetRootPart()
    if not root then return nil end
    local closestDist = radius or 5000
    local closestMob = nil
    for _, obj in ipairs(Workspace:GetDescendants()) do
        local pcallStatus, pcallResult = pcall(function()
            if obj:IsA("Model") and obj:FindFirstChild("HumanoidRootPart") and obj:FindFirstChildOfClass("Humanoid") then
                local hum = obj:FindFirstChildOfClass("Humanoid")
                if hum and hum.Health > 0 and not Players:GetPlayerFromCharacter(obj) then
                    local dist = (obj.HumanoidRootPart.Position - root.Position).Magnitude
                    if dist < closestDist and dist <= (radius or 5000) then
                        closestDist = dist
                        closestMob = obj
                    end
                end
            end
        end)
        if not pcallStatus then
            -- skip errors silently
        end
    end
    return closestMob
end

local function GetMobsByName(name, radius)
    local root = GetRootPart()
    if not root then return {} end
    local mobs = {}
    for _, obj in ipairs(Workspace:GetDescendants()) do
        local pcallStatus, pcallResult = pcall(function()
            if obj:IsA("Model") and obj:FindFirstChild("HumanoidRootPart") and obj:FindFirstChildOfClass("Humanoid") then
                local hum = obj:FindFirstChildOfClass("Humanoid")
                if hum and hum.Health > 0 and not Players:GetPlayerFromCharacter(obj) then
                    if obj.Name:lower():find(name:lower()) then
                        local dist = (obj.HumanoidRootPart.Position - root.Position).Magnitude
                        if dist <= (radius or State.BringRadius) then
                            table.insert(mobs, obj)
                        end
                    end
                end
            end
        end)
        if not pcallStatus then
            -- skip errors silently
        end
    end
    return mobs
end

local function SendNotification(title, text, duration)
    local pcallStatus, pcallResult = pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = title,
            Text = text,
            Duration = duration or 5
        })
    end)
end

local function IsInGame()
    return LocalPlayer and LocalPlayer.Parent ~= nil
end

-- ═══════════════════════════════════════════════════════════════════════
-- BLOCK ANTI-CHEAT TELEPORT WITH __NEWINDEX WALKT SPEED BYPASS
-- ═══════════════════════════════════════════════════════════════════════

local WalkSpeedMetaTable = {
    __newindex = function(self, index, value)
        if index == "WalkSpeed" then
            local char = GetCharacter()
            if char then
                local hum = char:FindFirstChildOfClass("Humanoid")
                if hum then
                    hum.WalkSpeed = State.WalkSpeed
                end
            end
            rawset(self, index, value)
        else
            rawset(self, index, value)
        end
    end
}

local function ApplyWalkSpeedBypass()
    if State.WalkSpeedConnection then
        State.WalkSpeedConnection:Disconnect()
        State.WalkSpeedConnection = nil
    end
    State.WalkSpeedConnection = RunService.Stepped:Connect(function()
        local pcallStatus, pcallResult = pcall(function()
            local char = GetCharacter()
            if char then
                local hum = char:FindFirstChildOfClass("Humanoid")
                if hum then
                    local metaTable = getmetatable(hum)
                    if not metaTable or metaTable ~= WalkSpeedMetaTable then
                        setmetatable(hum, WalkSpeedMetaTable)
                    end
                    hum.WalkSpeed = State.WalkSpeed
                end
            end
        end)
    end)
end

local function SetWalkSpeed(speed)
    State.WalkSpeed = math.clamp(speed, 16, 300)
    local char = GetCharacter()
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.WalkSpeed = State.WalkSpeed
        end
    end
end

-- ═══════════════════════════════════════════════════════════════════════
-- TAB 1: AUTO FARM SYSTEM
-- ═══════════════════════════════════════════════════════════════════════

local function AcceptQuest()
    local pcallStatus, pcallResult = pcall(function()
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj:IsA("Model") and obj:FindFirstChild("HumanoidRootPart") then
                local npcName = obj.Name:lower()
                if npcName:find("quest") or npcName:find("teacher") or npcName:find("master") or npcName:find("trainer") then
                    local npcRoot = obj:FindFirstChild("HumanoidRootPart")
                    if npcRoot then
                        local dist = (npcRoot.Position - GetRootPart().Position).Magnitude
                        if dist < 50 then
                            local args = {
                                [1] = "StartQuest",
                                [2] = obj.Name
                            }
                            local remoteEvent = nil
                            for _, descendant in ipairs(ReplicatedStorage:GetDescendants()) do
                                if descendant:IsA("RemoteEvent") and descendant.Name:find("Quest") then
                                    remoteEvent = descendant
                                    break
                                end
                            end
                            if remoteEvent then
                                remoteEvent:FireServer(unpack(args))
                            end
                            State.CurrentQuestNpc = obj.Name
                        end
                    end
                end
            end
        end
    end)
end

local function FindQuestMob()
    local pcallStatus, pcallResult = pcall(function()
        local playerLevel = LocalPlayer.Data and LocalPlayer.Data.Level and LocalPlayer.Data.Level.Value or 1
        local mobPriority = {}
        if playerLevel <= 10 then
            mobPriority = {"bandit", "thief", "pirate"}
        elseif playerLevel <= 30 then
            mobPriority = {"monkey", "gorilla"}
        elseif playerLevel <= 60 then
            mobPriority = {"marine", "soldier"}
        elseif playerLevel <= 90 then
            mobPriority = {"desert", "thief", "bandit"}
        elseif playerLevel <= 120 then
            mobPriority = {"snow", "ice"}
        elseif playerLevel <= 150 then
            mobPriority = {"jungle", "tribe"}
        elseif playerLevel <= 200 then
            mobPriority = {"ghost", "soul"}
        elseif playerLevel <= 250 then
            mobPriority = {"fish", "sea"}
        elseif playerLevel <= 300 then
            mobPriority = {"sky", "bird"}
        elseif playerLevel <= 400 then
            mobPriority = {"demon", "dark"}
        else
            mobPriority = {"dragon", "ninja", "samurai"}
        end
        for _, mobName in ipairs(mobPriority) do
            local mobs = GetMobsByName(mobName, 5000)
            if #mobs > 0 then
                State.CurrentQuestMob = mobName
                return mobs[1]
            end
        end
        return GetClosestMob(5000)
    end)
    return pcallResult
end

local function AutoFarmLoop()
    while State.AutoFarmEnabled and IsInGame() do
        local pcallStatus, pcallResult = pcall(function()
            local root = GetRootPart()
            if not root then return end
            if not State.TargetMob or not State.TargetMob:FindFirstChild("HumanoidRootPart") or not State.TargetMob:FindFirstChildOfClass("Humanoid") or State.TargetMob:FindFirstChildOfClass("Humanoid").Health <= 0 then
                State.TargetMob = FindQuestMob()
            end
            if State.TargetMob and State.TargetMob:FindFirstChild("HumanoidRootPart") then
                local mobRoot = State.TargetMob:FindFirstChild("HumanoidRootPart")
                local targetPos = mobRoot.Position + Vector3.new(0, 5, 0)
                local distance = (targetPos - root.Position).Magnitude
                if distance > 10 then
                    SafeTweenTo(CFrame.new(targetPos), State.TweenSpeed)
                end
                if distance <= 15 then
                    if State.FarmMethod == "Level Quest" and not State.CurrentQuestMob then
                        AcceptQuest()
                    end
                    local mobHum = State.TargetMob:FindFirstChildOfClass("Humanoid")
                    if mobHum and mobHum.Health > 0 then
                        if not State.AutoClickerRunning then
                            State.AutoClickerRunning = true
                            State.AutoClickConnection = RunService.Heartbeat:Connect(function()
                                local pcallStatus2, pcallResult2 = pcall(function()
                                    if State.AutoFarmEnabled and State.TargetMob and State.TargetMob:FindFirstChild("HumanoidRootPart") then
                                        VirtualUser:ClickButton1(Vector2.new(Mouse.X, Mouse.Y))
                                        local mobRoot2 = State.TargetMob:FindFirstChild("HumanoidRootPart")
                                        if mobRoot2 then
                                            local bringDist = (mobRoot2.Position - root.Position).Magnitude
                                            if bringDist > State.BringRadius then
                                                SafeTweenTo(CFrame.new(mobRoot2.Position + Vector3.new(0, 5, 0)), State.TweenSpeed)
                                            end
                                        end
                                    end
                                end)
                            end)
                        end
                    end
                end
            else
                State.TargetMob = FindQuestMob()
            end
        end)
        if not pcallStatus then
            warn("AutoFarm Error: " .. tostring(pcallResult))
        end
        task.wait(0.5)
    end
    if State.AutoClickConnection then
        State.AutoClickConnection:Disconnect()
        State.AutoClickConnection = nil
    end
    State.AutoClickerRunning = false
end

local function StartAutoFarm()
    if State.AutoFarmEnabled then return end
    State.AutoFarmEnabled = true
    SendNotification("⚔️ Auto Farm", "Auto Farm Level Activated!", 3)
    coroutine.wrap(function()
        AutoFarmLoop()
    end)()
end

local function StopAutoFarm()
    State.AutoFarmEnabled = false
    State.TargetMob = nil
    if State.AutoClickConnection then
        State.AutoClickConnection:Disconnect()
        State.AutoClickConnection = nil
    end
    State.AutoClickerRunning = false
    SendNotification("⚔️ Auto Farm", "Auto Farm Deactivated!", 2)
end

local function ToggleAutoFarm(value)
    if value then
        StartAutoFarm()
    else
        StopAutoFarm()
    end
end

-- ═══════════════════════════════════════════════════════════════════════
-- TAB 2: AUTO STATS ALLOCATION
-- ═══════════════════════════════════════════════════════════════════════

local function AllocateStats()
    while State.AutoMelee or State.AutoDefense or State.AutoSword do
        local pcallStatus, pcallResult = pcall(function()
            if LocalPlayer.Data and LocalPlayer.Data.StatPoints and LocalPlayer.Data.StatPoints.Value > 0 then
                local args = {}
                if State.AutoMelee then
                    args = {[1] = "AddPoint", [2] = "Melee"}
                    local remote = nil
                    for _, descendant in ipairs(ReplicatedStorage:GetDescendants()) do
                        if descendant:IsA("RemoteEvent") and descendant.Name:find("Stat") then
                            remote = descendant
                            break
                        end
                    end
                    if remote then
                        remote:FireServer(unpack(args))
                    end
                end
                if State.AutoDefense then
                    args = {[1] = "AddPoint", [2] = "Defense"}
                    local remote = nil
                    for _, descendant in ipairs(ReplicatedStorage:GetDescendants()) do
                        if descendant:IsA("RemoteEvent") and descendant.Name:find("Stat") then
                            remote = descendant
                            break
                        end
                    end
                    if remote then
                        remote:FireServer(unpack(args))
                    end
                end
                if State.AutoSword then
                    args = {[1] = "AddPoint", [2] = "Sword"}
                    local remote = nil
                    for _, descendant in ipairs(ReplicatedStorage:GetDescendants()) do
                        if descendant:IsA("RemoteEvent") and descendant.Name:find("Stat") then
                            remote = descendant
                            break
                        end
                    end
                    if remote then
                        remote:FireServer(unpack(args))
                    end
                end
            end
        end)
        if not pcallStatus then
            warn("AutoStats Error: " .. tostring(pcallResult))
        end
        task.wait(1.5)
    end
end

local function StartAutoStats()
    if State.AutoStatConnection then return end
    State.AutoStatConnection = coroutine.wrap(function()
        AllocateStats()
    end)()
end

local function StopAutoStats()
    State.AutoStatConnection = nil
end

-- ═══════════════════════════════════════════════════════════════════════
-- TAB 2: SAFE ISLAND TELEPORT
-- ═══════════════════════════════════════════════════════════════════════

local IslandLocations = {
    ["Starter"] = CFrame.new(0, 50, 0),
    ["Jungle"] = CFrame.new(-600, 50, -800),
    ["Marineford"] = CFrame.new(1600, 50, 500),
    ["Desert"] = CFrame.new(-1200, 50, 1200),
    ["Green Zone"] = CFrame.new(800, 50, -1200),
    ["Castle"] = CFrame.new(-1800, 50, -600)
}

local function TeleportToIsland(islandName)
    local pcallStatus, pcallResult = pcall(function()
        if State.TeleportCooldown then
            SendNotification("⏳ Cooldown", "Please wait before teleporting again!", 2)
            return
        end
        local targetCFrame = IslandLocations[islandName]
        if not targetCFrame then
            SendNotification("❌ Error", "Island not found: " .. islandName, 2)
            return
        end
        SendNotification("🌌 Teleporting", "Flying to " .. islandName .. "...", 3)
        if State.BypassTeleport then
            local root = GetRootPart()
            if root then
                root.CFrame = targetCFrame
            end
        else
            SafeTweenTo(targetCFrame, State.TweenSpeed)
        end
        State.TeleportCooldown = true
        task.delay(5, function()
            State.TeleportCooldown = false
        end)
    end)
    if not pcallStatus then
        warn("Teleport Error: " .. tostring(pcallResult))
    end
end

-- ═══════════════════════════════════════════════════════════════════════
-- TAB 3: ESP SYSTEMS
-- ═══════════════════════════════════════════════════════════════════════

local ESPFolder = nil

local function CreateESPFolder()
    if ESPFolder and ESPFolder.Parent then return ESPFolder end
    ESPFolder = CreateInstance("Folder", {
        Name = "OnyxESP",
        Parent = CoreGui
    })
end

local function ClearESP()
    for _, obj in ipairs(State.ESPObjects) do
        if obj and obj.Parent then
            obj:Destroy()
        end
    end
    State.ESPObjects = {}
    if ESPFolder and ESPFolder.Parent then
        for _, child in ipairs(ESPFolder:GetChildren()) do
            child:Destroy()
        end
    end
end

local function CreatePlayerESP(player)
    local pcallStatus, pcallResult = pcall(function()
        local char = player.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        local billboard = CreateInstance("BillboardGui", {
            Name = "PlayerESP_" .. player.Name,
            Size = UDim2.new(0, 100, 0, 40),
            StudsOffset = Vector3.new(0, 4, 0),
            AlwaysOnTop = true,
            ClipsDescendants = false,
            Parent = root
        })
        local isEnemy = false
        if player.Team and LocalPlayer.Team then
            isEnemy = player.Team ~= LocalPlayer.Team
        end
        local espColor = isEnemy and Color3.fromRGB(255, 50, 50) or Color3.fromRGB(50, 255, 50)
        local nameLabel = CreateInstance("TextLabel", {
            Name = "NameLabel",
            Size = UDim2.new(1, 0, 0.5, 0),
            Position = UDim2.new(0, 0, 0, 0),
            BackgroundTransparency = 1,
            Text = player.Name,
            TextColor3 = espColor,
            TextSize = 12,
            Font = Enum.Font.GothamBold,
            TextStrokeTransparency = 0.3,
            TextStrokeColor3 = Color3.fromRGB(0, 0, 0),
            TextXAlignment = Enum.TextXAlignment.Center,
            TextYAlignment = Enum.TextYAlignment.Bottom,
            Parent = billboard
        })
        local distLabel = CreateInstance("TextLabel", {
            Name = "DistLabel",
            Size = UDim2.new(1, 0, 0.5, 0),
            Position = UDim2.new(0, 0, 0.5, 0),
            BackgroundTransparency = 1,
            Text = "0m",
            TextColor3 = espColor,
            TextSize = 11,
            Font = Enum.Font.Gotham,
            TextStrokeTransparency = 0.3,
            TextStrokeColor3 = Color3.fromRGB(0, 0, 0),
            TextXAlignment = Enum.TextXAlignment.Center,
            TextYAlignment = Enum.TextYAlignment.Top,
            Parent = billboard
        })
        local updateConnection = RunService.Heartbeat:Connect(function()
            local pcallStatus2, pcallResult2 = pcall(function()
                if not billboard or not billboard.Parent then
                    updateConnection:Disconnect()
                    return
                end
                local char2 = player.Character
                if not char2 or not char2:FindFirstChild("HumanoidRootPart") then
                    billboard.Enabled = false
                    return
                end
                billboard.Enabled = State.PlayerESP
                local myRoot = GetRootPart()
                if myRoot then
                    local dist = (char2.HumanoidRootPart.Position - myRoot.Position).Magnitude
                    distLabel.Text = math.floor(dist) .. "m"
                end
                local isEnemy2 = false
                if player.Team and LocalPlayer.Team then
                    isEnemy2 = player.Team ~= LocalPlayer.Team
                end
                local color = isEnemy2 and Color3.fromRGB(255, 50, 50) or Color3.fromRGB(50, 255, 50)
                nameLabel.TextColor3 = color
                distLabel.TextColor3 = color
            end)
        end)
        table.insert(State.ESPObjects, billboard)
        return billboard
    end)
end

local function UpdatePlayerESP()
    ClearESP()
    if not State.PlayerESP then return end
    CreateESPFolder()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            CreatePlayerESP(player)
        end
    end
    Players.PlayerAdded:Connect(function(player)
        if State.PlayerESP then
            CreatePlayerESP(player)
        end
    end)
end

local function TogglePlayerESP(value)
    State.PlayerESP = value
    if value then
        UpdatePlayerESP()
        SendNotification("👁️ ESP", "Player ESP Activated!", 2)
    else
        ClearESP()
        SendNotification("👁️ ESP", "Player ESP Deactivated!", 2)
    end
end

-- Legendary Dealer Tracker
local function FindLegendaryDealer()
    local pcallStatus, pcallResult = pcall(function()
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj:IsA("Model") and obj:FindFirstChild("HumanoidRootPart") then
                local name = obj.Name:lower()
                if name:find("dealer") or name:find("trader") or name:find("merchant") then
                    return obj
                end
            end
        end
    end)
    return pcallResult
end

local function ToggleLegendaryTracker(value)
    State.LegendaryTracker = value
    if value then
        if not State.ESPConnections["LegendaryDealer"] then
            State.ESPConnections["LegendaryDealer"] = RunService.Heartbeat:Connect(function()
                local pcallStatus, pcallResult = pcall(function()
                    if not State.LegendaryTracker then return end
                    local dealer = FindLegendaryDealer()
                    if dealer and dealer:FindFirstChild("HumanoidRootPart") then
                        local dealerRoot = dealer:FindFirstChild("HumanoidRootPart")
                        local myRoot = GetRootPart()
                        if myRoot then
                            local dist = (dealerRoot.Position - myRoot.Position).Magnitude
                            if dist < 500 then
                                -- Flash notification
                                SendNotification("💰 Legendary Dealer", "Dealer spotted at " .. tostring(math.floor(dist)) .. "m!", 3)
                                -- Purple tracer line
                                local ray = Ray.new(myRoot.Position, (dealerRoot.Position - myRoot.Position).Unit * dist)
                                local handlePart = CreateInstance("Part", {
                                    Name = "DealerTracer",
                                    Size = Vector3.new(0.2, 0.2, dist),
                                    Position = myRoot.Position + (dealerRoot.Position - myRoot.Position) / 2,
                                    CFrame = CFrame.new(myRoot.Position, dealerRoot.Position),
                                    Color = CONFIG.NeonPurple,
                                    Material = Enum.Material.Neon,
                                    Transparency = 0.3,
                                    Anchored = true,
                                    CanCollide = false,
                                    Parent = ESPFolder or Workspace
                                })
                                Debris:AddItem(handlePart, 0.2)
                            end
                        end
                    end
                end)
            end)
        end
    else
        if State.ESPConnections["LegendaryDealer"] then
            State.ESPConnections["LegendaryDealer"]:Disconnect()
            State.ESPConnections["LegendaryDealer"] = nil
        end
    end
end

-- Devil Fruit ESP
local function ToggleDevilFruitESP(value)
    State.DevilFruitESP = value
    if value then
        if not State.ESPConnections["DevilFruit"] then
            State.ESPConnections["DevilFruit"] = RunService.Heartbeat:Connect(function()
                local pcallStatus, pcallResult = pcall(function()
                    if not State.DevilFruitESP then return end
                    for _, obj in ipairs(Workspace:GetDescendants()) do
                        if obj:IsA("Tool") and obj:FindFirstChild("Handle") then
                            local name = obj.Name:lower()
                            if name:find("fruit") or name:find("gura") or name:find("magu") or name:find("mera") or name:find("goro") or name:find("yami") then
                                if not obj:FindFirstChild("ESPTag") then
                                    local selectionBox = CreateInstance("SelectionBox", {
                                        Name = "ESPTag",
                                        Adornee = obj,
                                        Color3 = Color3.fromRGB(255, 255, 0),
                                        LineThickness = 0.1,
                                        Transparency = 0.5,
                                        Parent = CoreGui
                                    })
                                    table.insert(State.ESPObjects, selectionBox)
                                    local billboard = CreateInstance("BillboardGui", {
                                        Name = "FruitLabel",
                                        Size = UDim2.new(0, 100, 0, 20),
                                        StudsOffset = Vector3.new(0, 2, 0),
                                        AlwaysOnTop = true,
                                        Parent = obj:FindFirstChild("Handle") or obj
                                    })
                                    CreateTextLabel(UDim2.new(1, 0, 1, 0), UDim2.new(0, 0, 0, 0), "🍎 " .. obj.Name, Color3.fromRGB(255, 255, 0), 12, billboard)
                                    table.insert(State.ESPObjects, billboard)
                                end
                            end
                        end
                    end
                end)
            end)
        end
    else
        if State.ESPConnections["DevilFruit"] then
            State.ESPConnections["DevilFruit"]:Disconnect()
            State.ESPConnections["DevilFruit"] = nil
        end
        for _, obj in ipairs(CoreGui:GetDescendants()) do
            if obj.Name == "ESPTag" then
                obj:Destroy()
            end
            if obj.Name == "FruitLabel" then
                obj:Destroy()
            end
        end
    end
end

