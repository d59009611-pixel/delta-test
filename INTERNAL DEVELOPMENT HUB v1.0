local teleportButton = Instance.new("TextButton")
teleportButton.Name = "TeleportButton"
teleportButton.Size = UDim2.new(0, 140, 0, 34)
teleportButton.Position = UDim2.new(0, 10, 0, 60)
teleportButton.BackgroundColor3 = CONFIG.PrimaryColor
teleportButton.Text = "Телепорт"
teleportButton.TextColor3 = CONFIG.TextColor
teleportButton.Font = Enum.Font.GothamBold
teleportButton.TextSize = 14
teleportButton.Parent = teleportContent

local tpBtnCorner = Instance.new("UICorner")
tpBtnCorner.CornerRadius = UDim.new(0, 6)
tpBtnCorner.Parent = teleportButton

teleportButton.MouseButton1Click:Connect(function()
	local success, err = pcall(function()
		local x = tonumber(inputX.Text)
		local y = tonumber(inputY.Text)
		local z = tonumber(inputZ.Text)

		if x and y and z then
			local character = player.Character
			local hrp = character and character:FindFirstChild("HumanoidRootPart")
			if hrp then
				local targetCFrame = CFrame.new(x, y, z)
				local tweenInfo = TweenInfo.new(
					1.5,
					Enum.EasingStyle.Quad,
					Enum.EasingDirection.Out
				)
				local tween = TweenService:Create(hrp, tweenInfo, {CFrame = targetCFrame})
				tween:Play()
			end
		end
	end)
	if not success then
		warn("Teleport error: " .. tostring(err))
	end
end)

-- Пресетные точки
local presets = {
	{"Spawn", Vector3.new(0, 50, 0)},
	{"Base", Vector3.new(100, 50, 100)},
	{"Shop", Vector3.new(-100, 50, -100)}
}

for i, preset in ipairs(presets) do
	local pName, pPos = preset[1], preset[2]
	local presetBtn = Instance.new("TextButton")
	presetBtn.Name = pName .. "Preset"
	presetBtn.Size = UDim2.new(0, 290, 0, 30)
	presetBtn.Position = UDim2.new(0, 10, 0, 110 + (i - 1) * 40)
	presetBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
	presetBtn.Text = pName .. "  " .. tostring(pPos)
	presetBtn.TextColor3 = CONFIG.SubTextColor
	presetBtn.Font = Enum.Font.Gotham
	presetBtn.TextSize = 12
	presetBtn.Parent = teleportContent

	local pCorner = Instance.new("UICorner")
	pCorner.CornerRadius = UDim.new(0, 6)
	pCorner.Parent = presetBtn

	presetBtn.MouseButton1Click:Connect(function()
		local success, err = pcall(function()
			local character = player.Character
			local hrp = character and character:FindFirstChild("HumanoidRootPart")
			if hrp then
				local tweenInfo = TweenInfo.new(
					2,
					Enum.EasingStyle.Quad,
					Enum.EasingDirection.Out
				)
				local tween = TweenService:Create(hrp, tweenInfo, {CFrame = CFrame.new(pPos)})
				tween:Play()
			end
		end)
		if not success then
			warn("Preset teleport error: " .. tostring(err))
		end
	end)
end

--// ============================================
--// ВКЛАДКА 3: ВИЗУАЛЬНЫЕ ЭФФЕКТЫ
--// ============================================
local visualContent = tabContents["Визуальные эффекты"]

local highlightContainer, highlightBtn, getHighlightState, setHighlightState = createToggle(
	visualContent,
	"Подсветка важных блоков",
	UDim2.new(0, 10, 0, 15)
)

highlightBtn.MouseButton1Click:Connect(function()
	local newState = not getHighlightState()
	setHighlightState(newState)
end)

local activeHighlights = {}
local lastScan = 0

RunService.Heartbeat:Connect(function()
	local success = pcall(function()
		if not getHighlightState() then
			for part, box in pairs(activeHighlights) do
				if box and box.Parent then
					box:Destroy()
				end
			end
			activeHighlights = {}
			return
		end

		if tick() - lastScan < 0.5 then
			return
		end
		lastScan = tick()

		-- Поиск новых блоков
		for _, obj in ipairs(Workspace:GetDescendants()) do
			if obj:IsA("BasePart") and obj.Name == "ImportantBlock" then
				if not activeHighlights[obj] then
					local selectionBox = Instance.new("SelectionBox")
					selectionBox.Name = "AdminHighlightBox"
					selectionBox.Adornee = obj
					selectionBox.Color3 = Color3.fromRGB(255, 255, 0)
					selectionBox.LineThickness = 0.05
					selectionBox.Parent = obj
					activeHighlights[obj] = selectionBox
				end
			end
		end

		-- Очистка удалённых блоков
		for part, box in pairs(activeHighlights) do
			if not part:IsDescendantOf(Workspace) then
				if box and box.Parent then
					box:Destroy()
				end
				activeHighlights[part] = nil
			end
		end
	end)

	if not success then
		-- Тихий сброс при ошибке
		for part, box in pairs(activeHighlights) do
			if box and box.Parent then
				box:Destroy()
			end
		end
		activeHighlights = {}
	end
end)

--// ============================================
--// СИСТЕМА СВОРАЧИВАНИЯ / РАЗВОРАЧИВАНИЯ
--// ============================================
closeButton.MouseButton1Click:Connect(function()
	mainFrame.Visible = false
	toggleCircle.Visible = true
end)

toggleCircle.MouseButton1Click:Connect(function()
	mainFrame.Visible = true
	toggleCircle.Visible = false
end)

--// Перетаскивание основного окна
makeDraggable(mainFrame, topBar)

--// Перетаскивание круглой кнопки (мобильная поддержка)
makeDraggable(toggleCircle, toggleCircle)

--// Инициализация первой вкладки
switchTab("Управление")
