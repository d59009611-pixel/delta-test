-- 🔮 ONYX MATRIX PROJECTS v1.0
-- Premium Mobile Script Hub for Blox Fruits (Roblox)
-- UI Core Framework & Tab Navigation System
-- Optimized for Delta Executor (Android)

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local GuiService = game:GetService("GuiService")

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

-- Configuration
local CONFIG = {
    MainFrameSize = UDim2.new(0, 450, 0, 300),
    MainFramePosition = UDim2.new(0.5, -225, 0.5, -150),
    BackgroundColor = Color3.fromRGB(10, 10, 15),
    NeonPurple = Color3.fromRGB(180, 0, 255),
    TextColor = Color3.fromRGB(255, 255, 255),
    SecondaryText = Color3.fromRGB(180, 180, 180),
    ButtonColor = Color3.fromRGB(20, 20, 30),
    ButtonHover = Color3.fromRGB(30, 30, 45),
    TabHeight = 40,
    ColumnWidth = 210,
    ToggleSize = 40
}

-- UI Instance Cache
local UI = {}

-- Utility Functions
local function CreateInstance(instanceType, properties)
    local instance = Instance.new(instanceType)
    for property, value in pairs(properties) do
        instance[property] = value
    end
    return instance
end

local function CreateUIStroke(color, thickness, transparency)
    return CreateInstance("UIStroke", {
        Color = color,
        Thickness = thickness,
        Transparency = transparency or 0
    })
end

local function CreateTextLabel(size, position, text, textColor, fontSize, parent)
    local label = CreateInstance("TextLabel", {
        Size = size,
        Position = position,
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = textColor,
        TextSize = fontSize,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Center,
        TextYAlignment = Enum.TextYAlignment.Center,
        Parent = parent
    })
    return label
end

local function CreateButton(size, position, backgroundColor, parent)
    local button = CreateInstance("TextButton", {
        Size = size,
        Position = position,
        BackgroundColor3 = backgroundColor,
        Text = "",
        AutoButtonColor = false,
        Parent = parent
    })
    return button
end

-- Tween Helper
local function TweenObject(instance, properties, duration, style, direction)
    local tweenInfo = TweenInfo.new(
        duration or 0.3,
        style or Enum.EasingStyle.Quad,
        direction or Enum.EasingDirection.Out
    )
    local tween = TweenService:Create(instance, tweenInfo, properties)
    tween:Play()
    return tween
end

-- ============================================
-- MAIN UI CONSTRUCTION
-- ============================================

-- ScreenGui Container
UI.ScreenGui = CreateInstance("ScreenGui", {
    Name = "OnyxMatrixProjects",
    Parent = PlayerGui,
    ResetOnSpawn = false,
    ZIndexBehavior = Enum.ZIndexBehavior.Sibling
})

-- Main Frame
UI.MainFrame = CreateInstance("Frame", {
    Name = "MainFrame",
    Size = CONFIG.MainFrameSize,
    Position = CONFIG.MainFramePosition,
    BackgroundColor3 = CONFIG.BackgroundColor,
    ClipsDescendants = true,
    Parent = UI.ScreenGui
})

-- Neon Purple Border (UIStroke)
CreateUIStroke(CONFIG.NeonPurple, 2, 0).Parent = UI.MainFrame

-- UI Corner for rounded edges
CreateInstance("UICorner", {
    CornerRadius = UDim.new(0, 8),
    Parent = UI.MainFrame
})

-- Title Bar
UI.TitleBar = CreateInstance("Frame", {
    Name = "TitleBar",
    Size = UDim2.new(1, 0, 0, 30),
    Position = UDim2.new(0, 0, 0, 0),
    BackgroundColor3 = Color3.fromRGB(15, 15, 25),
    Parent = UI.MainFrame
})
CreateInstance("UICorner", {
    CornerRadius = UDim.new(0, 8),
    Parent = UI.TitleBar
})
CreateTextLabel(
    UDim2.new(0, 200, 1, 0),
    UDim2.new(0, 10, 0, 0),
    "🔮 ONYX MATRIX v1.0",
