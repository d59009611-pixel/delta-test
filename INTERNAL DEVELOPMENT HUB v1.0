-- ═══════════════════════════════════════════════════════════════════════
-- TAB 4: AUTO BUY SHOP & FRUIT SNIPER
-- ═══════════════════════════════════════════════════════════════════════

local function AutoBuyShopLoop()
    while State.AutoBuyShop do
        local pcallStatus, pcallResult = pcall(function()
            local playerLevel = LocalPlayer.Data and LocalPlayer.Data.Level and LocalPlayer.Data.Level.Value or 1
            local playerBeli = LocalPlayer.Data and LocalPlayer.Data.Beli and LocalPlayer.Data.Beli.Value or 0
            for _, obj in ipairs(Workspace:GetDescendants()) do
                if obj:IsA("Model") and obj:FindFirstChild("HumanoidRootPart") then
                    local npcName = obj.Name:lower()
                    if npcName:find("teacher") or npcName:find("master") or npcName:find("shop") or npcName:find("vendor") then
                        local npcRoot = obj:FindFirstChild("HumanoidRootPart")
                        if npcRoot and (npcRoot.Position - GetRootPart().Position).Magnitude < 50 then
                            -- Try to purchase fighting styles or swords
                            local args = {
                                [1] = "Buy",
                                [2] = obj.Name,
                                [3] = "FightingStyle"
                            }
                            for _, descendant in ipairs(ReplicatedStorage:GetDescendants()) do
                                if descendant:IsA("RemoteEvent") and (descendant.Name:find("Shop") or descendant.Name:find("Purchase") or descendant.Name:find("Buy")) then
                                    descendant:FireServer(unpack(args))
                                end
                            end
                        end
                    end
                end
            end
        end)
        if not pcallStatus then
            warn("AutoBuy Error: " .. tostring(pcallResult))
        end
        task.wait(3)
    end
end

local function FruitSniperLoop()
    while State.FruitSniper do
        local pcallStatus, pcallResult = pcall(function()
            for _, obj in ipairs(Workspace:GetDescendants()) do
                if obj:IsA("Model") and obj:FindFirstChild("HumanoidRootPart") then
                    local npcName = obj.Name:lower()
                    if npcName:find("dealer") or npcName:find("fruit") then
                        local npcRoot = obj:FindFirstChild("HumanoidRootPart")
                        if npcRoot and (npcRoot.Position - GetRootPart().Position).Magnitude < 50 then
                            local remoteEvent = nil
                            for _, descendant in ipairs(ReplicatedStorage:GetDescendants()) do
                                if descendant:IsA("RemoteEvent") and (descendant.Name:find("Fruit") or descendant.Name:find("Buy") or descendant.Name:find("Purchase")) then
                                    remoteEvent = descendant
                                    break
                                end
                            end
                            if remoteEvent then
                                remoteEvent:FireServer("BuyFruit", obj.Name)
                                SendNotification("🍎 Fruit Sniper", "Attempting to buy fruit from " .. obj.Name, 3)
                            end
                        end
                    end
                end
            end
        end)
        if not pcallStatus then
            warn("FruitSniper Error: " .. tostring(pcallResult))
        end
        task.wait(0.5)
    end
end

-- ═══════════════════════════════════════════════════════════════════════
-- TAB 4: AUTO RAID & DUNGEON
-- ═══════════════════════════════════════════════════════════════════════

local function AutoRaidLoop()
    while State.AutoRaid do
        local pcallStatus, pcallResult = pcall(function()
            -- Find raid entrance or dungeon zone
            local raidZone = nil
            for _, obj in ipairs(Workspace:GetDescendants()) do
                if obj:IsA("BasePart") and (obj.Name:lower():find("raid") or obj.Name:lower():find("dungeon") or obj.Name:lower():find("portal") or obj.Name:lower():find("gate")) then
                    local myRoot = GetRootPart()
                    if myRoot then
                        local dist = (obj.Position - myRoot.Position).Magnitude
                        if dist < 100 then
                            raidZone = obj
                            break
                        end
                    end
                end
            end
            if raidZone then
                local myRoot = GetRootPart()
                if myRoot then
                    SafeTweenTo(CFrame.new(raidZone.Position + Vector3.new(0, 3, 0)), State.TweenSpeed)
                    task.wait(1)
                    VirtualUser:ClickButton1(Vector2.new(Mouse.X, Mouse.Y))
                    task.wait(0.5)
                    VirtualUser:ClickButton1(Vector2.new(Mouse.X, Mouse.Y))
                end
            end
        end)
        if not pcallStatus then
            warn("AutoRaid Error: " .. tostring(pcallResult))
        end
        task.wait(2)
    end
end

-- ═══════════════════════════════════════════════════════════════════════
-- DESTROY SCRIPT SAFE CLEANUP
-- ═══════════════════════════════════════════════════════════════════════

local function DestroyScript()
    State.ScriptDestroyed = true
    State.AutoFarmEnabled = false
    State.AutoMelee = false
    State.AutoDefense = false
    State.AutoSword = false
    State.PlayerESP = false
    State.LegendaryTracker = false
    State.DevilFruitESP = false
    State.HakiBerryESP = false
    State.ChestESP = false
    State.AutoBuyShop = false
    State.FruitSniper = false
    State.AutoRaid = false
    if State.AutoClickConnection then
        State.AutoClickConnection:Disconnect()
        State.AutoClickConnection = nil
    end
    if State.WalkSpeedConnection then
        State.WalkSpeedConnection:Disconnect()
        State.WalkSpeedConnection = nil
    end
    if State.AutoFarmConnection then
        State.AutoFarmConnection:Disconnect()
        State.AutoFarmConnection = nil
    end
    for _, conn in pairs(State.ESPConnections) do
        if conn then
            conn:Disconnect()
        end
    end
    State.ESPConnections = {}
    ClearESP()
    if UI and UI.ScreenGui and UI.ScreenGui.Parent then
        UI.ScreenGui:Destroy()
    end
    if ESPFolder and ESPFolder.Parent then
        ESPFolder:Destroy()
    end
    for _, obj in ipairs(CoreGui:GetDescendants()) do
        if obj.Name:find("Onyx") or obj.Name:find("ESPTag") or obj.Name:find("ChestLabel") or obj.Name:find("FruitLabel") or obj.Name:find("MaterialLabel") or obj.Name:find("PlayerESP") then
            obj:Destroy()
        end
    end
    SendNotification("🔮 ONYX MATRIX", "Script successfully destroyed. Goodbye!", 3)
end

-- ═══════════════════════════════════════════════════════════════════════
-- UI CONSTRUCTION — All Instances
-- ═══════════════════════════════════════════════════════════════════════

local UI = {}

-- ScreenGui Container
UI.ScreenGui = CreateInstance("ScreenGui", {
    Name = "OnyxMatrixProjects",
    Parent = PlayerGui,
    ResetOnSpawn = false,
    ZIndexBehavior = Enum.ZIndexBehavior.Sibling
})

-- Main Frame
UI.MainFrame = CreateInstance("Frame", {
    Name = "MainFrame",
    Size = CONFIG.MainFrameSize,
    Position = CONFIG.MainFramePosition,
    BackgroundColor3 = CONFIG.BackgroundColor,
    ClipsDescendants = true,
    Parent = UI.ScreenGui
})
CreateUIStroke(CONFIG.NeonPurple, 2, 0).Parent = UI.MainFrame
CreateInstance("UICorner", {
    CornerRadius = UDim.new(0, 8),
    Parent = UI.MainFrame
})

-- Title Bar
UI.TitleBar = CreateInstance("Frame", {
    Name = "TitleBar",
    Size = UDim2.new(1, 0, 0, 30),
    Position = UDim2.new(0, 0, 0, 0),
    BackgroundColor3 = Color3.fromRGB(15, 15, 25),
    Parent = UI.MainFrame
})
CreateInstance("UICorner", {
    CornerRadius = UDim.new(0, 8),
    Parent = UI.TitleBar
})
CreateTextLabel(UDim2.new(0, 200, 1, 0), UDim2.new(0, 10, 0, 0), "🔮 ONYX MATRIX v1.0", CONFIG.NeonPurple, 14, UI.TitleBar)

-- Minimize Button (X)
UI.MinimizeBtn = CreateButton(UDim2.new(0, 30, 1, 0), UDim2.new(1, -30, 0, 0), CONFIG.ButtonColor, UI.TitleBar)
CreateInstance("UICorner", {CornerRadius = UDim.new(0, 4), Parent = UI.MinimizeBtn})
CreateTextLabel(UDim2.new(1, 0, 1, 0), UDim2.new(0, 0, 0, 0), "✕", CONFIG.TextColor, 16, UI.MinimizeBtn)

-- Tab Container
UI.TabContainer = CreateInstance("Frame", {
    Name = "TabContainer",
    Size = UDim2.new(1, -20, 0, CONFIG.TabHeight),
    Position = UDim2.new(0, 10, 0, 40),
    BackgroundTransparency = 1,
    Parent = UI.MainFrame
})

-- Tab Button Data
local TabNames = {"Main Farm", "Stats & Teleport", "Visuals & ESP", "Shop & Settings"}
UI.TabButtons = {}
UI.TabFrames = {}
local ActiveTab = 1

-- Create Tab Buttons
local tabWidth = (CONFIG.MainFrameSize.X.Offset - 20) / 4
for i, tabName in ipairs(TabNames) do
    local tabBtn = CreateButton(UDim2.new(0, tabWidth, 1, 0), UDim2.new((i-1) * (1/4), 0, 0, 0), i == 1 and CONFIG.NeonPurple or CONFIG.ButtonColor, UI.TabContainer)
    CreateInstance("UICorner", {CornerRadius = UDim.new(0, 4), Parent = tabBtn})
    CreateTextLabel(UDim2.new(1, 0, 1, 0), UDim2.new(0, 0, 0, 0), tabName, CONFIG.TextColor, 12, tabBtn)
    UI.TabButtons[i] = {Button = tabBtn, Name = tabName, Index = i}
end

-- Create Tab Content Frame Factory
local function CreateTabContentFrame(tabIndex)
    local contentFrame = CreateInstance("Frame", {
        Name = "TabContent_" .. tabIndex,
        Size = UDim2.new(1, -20, 1, -CONFIG.TabHeight - 50),
        Position = UDim2.new(0, 10, 0, CONFIG.TabHeight + 50),
        BackgroundTransparency = 1,
        Visible = tabIndex == 1,
        Parent = UI.MainFrame
    })
    local leftColumn = CreateInstance("ScrollingFrame", {
        Name = "LeftColumn",
        Size = UDim2.new(0.5, -5, 1, 0),
        Position = UDim2.new(0, 0, 0, 0),
        BackgroundTransparency = 1,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        ScrollBarThickness = 4,
        ScrollBarImageColor3 = CONFIG.NeonPurple,
        Parent = contentFrame
    })
    CreateInstance("UIListLayout", {Padding = UDim.new(0, 6), Parent = leftColumn})
    CreateInstance("UIPadding", {PaddingLeft = UDim.new(0, 4), Parent = leftColumn})
    local rightColumn = CreateInstance("ScrollingFrame", {
        Name = "RightColumn",
        Size = UDim2.new(0.5, -5, 1, 0),
        Position = UDim2.new(0.5, 5, 0, 0),
        BackgroundTransparency = 1,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        ScrollBarThickness = 4,
        ScrollBarImageColor3 = CONFIG.NeonPurple,
        Parent = contentFrame
    })
    CreateInstance("UIListLayout", {Padding = UDim.new(0, 6), Parent = rightColumn})
    CreateInstance("UIPadding", {PaddingLeft = UDim.new(0, 4), Parent = rightColumn})
    return {Frame = contentFrame, LeftColumn = leftColumn, RightColumn = rightColumn}
end

-- Create all 4 tab content frames
for i = 1, 4 do
    UI.TabFrames[i] = CreateTabContentFrame(i)
end

-- Toggle Button (Minimized Circle)
UI.ToggleBtn = CreateInstance("Frame", {
    Name = "ToggleBtn",
    Size = UDim2.new(0, CONFIG.ToggleSize, 0, CONFIG.ToggleSize),
    Position = UDim2.new(0, 0, 0, 0),
    BackgroundColor3 = CONFIG.NeonPurple,
    Visible = false,
    Parent = UI.ScreenGui
})
CreateInstance("UICorner", {CornerRadius = UDim.new(1, 0), Parent = UI.ToggleBtn})
CreateUIStroke(Color3.fromRGB(255, 255, 255), 2, 0).Parent = UI.ToggleBtn
CreateTextLabel(UDim2.new(1, 0, 1, 0), UDim2.new(0, 0, 0, 0), "⚙", CONFIG.TextColor, 18, UI.ToggleBtn)

-- Draggable Toggle Logic
local draggingToggle = false
local toggleDragOffset = Vector2.new()
UI.ToggleBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        draggingToggle = true
        toggleDragOffset = UI.ToggleBtn.AbsolutePosition - input.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                draggingToggle = false
            end
        end)
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if draggingToggle and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local newPosition = input.Position + toggleDragOffset
        UI.ToggleBtn.Position = UDim2.fromOffset(newPosition.X, newPosition.Y)
    end
end)
UI.ToggleBtn.MouseButton1Click:Connect(function()
    UI.MainFrame.Visible = true
    UI.ToggleBtn.Visible = false
    UI.MainFrame.BackgroundTransparency = 1
    TweenObject(UI.MainFrame, {BackgroundTransparency = 0}, 0.3)
end)
UI.MinimizeBtn.MouseButton1Click:Connect(function()
    UI.MainFrame.Visible = false
    UI.ToggleBtn.Visible = true
    local screenGuiSize = UI.ScreenGui.AbsoluteWindowSize
    UI.ToggleBtn.Position = UDim2.fromOffset(screenGuiSize.X - CONFIG.ToggleSize - 10, screenGuiSize.Y - CONFIG.ToggleSize - 10)
end)

-- Tab Switching Logic
local function SwitchTab(tabIndex)
    if tabIndex < 1 or tabIndex > 4 then return end
    for i = 1, 4 do
        UI.TabFrames[i].Frame.Visible = (i == tabIndex)
    end
    for i, tabData in ipairs(UI.TabButtons) do
        local targetColor = (i == tabIndex) and CONFIG.NeonPurple or CONFIG.ButtonColor
        TweenObject(tabData.Button, {BackgroundColor3 = targetColor}, 0.2)
    end
    ActiveTab = tabIndex
end
for i, tabData in ipairs(UI.TabButtons) do
    tabData.Button.MouseButton1Click:Connect(function()
        SwitchTab(i)
    end)
end

-- Main Frame Draggable
local draggingMain = false
local mainDragOffset = Vector2.new()
local mainFrameDragging = false
UI.TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        mainFrameDragging = true
        draggingMain = true
        mainDragOffset = UI.MainFrame.AbsolutePosition - input.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                draggingMain = false
            end
        end)
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if draggingMain and mainFrameDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local newPosition = input.Position + mainDragOffset
        UI.MainFrame.Position = UDim2.fromOffset(newPosition.X, newPosition.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        mainFrameDragging = false
    end
end)

-- Auto-update ScrollingFrame Canvas Size
for i = 1, 4 do
    local leftLayout = UI.TabFrames[i].LeftColumn:FindFirstChildOfClass("UIListLayout")
    local rightLayout = UI.TabFrames[i].RightColumn:FindFirstChildOfClass("UIListLayout")
    if leftLayout then
        leftLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            UI.TabFrames[i].LeftColumn.CanvasSize = UDim2.new(0, 0, 0, leftLayout.AbsoluteContentSize.Y + 10)
        end)
    end
    if rightLayout then
        rightLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            UI.TabFrames[i].RightColumn.CanvasSize = UDim2.new(0, 0, 0, rightLayout.AbsoluteContentSize.Y + 10)
        end)
    end
end

-- ═══════════════════════════════════════════════════════════════════════
-- UI HELPER FUNCTIONS for Building Content
-- ═══════════════════════════════════════════════════════════════════════

function UI.CreateButton(column, text, callback)
    local buttonFrame = CreateInstance("Frame", {
        Name = "Btn_" .. text:gsub("%s+", "_"),
        Size = UDim2.new(1, -10, 0, 32),
        BackgroundTransparency = 1,
        Parent = column
    })
    local button = CreateButton(UDim2.new(1, 0, 1, 0), UDim2.new(0, 0, 0, 0), CONFIG.ButtonColor, buttonFrame)
    CreateInstance("UICorner", {CornerRadius = UDim.new(0, 6), Parent = button})
    CreateTextLabel(UDim2.new(1, 0, 1, 0), UDim2.new(0, 0, 0, 0), text, CONFIG.TextColor, 12, button)
    button.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            TweenObject(button, {BackgroundColor3 = CONFIG.ButtonHover}, 0.2)
        end
    end)
    button.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            TweenObject(button, {BackgroundColor3 = CONFIG.ButtonColor}, 0.2)
        end
    end)
    button.MouseButton1Click:Connect(function()
        if callback then
            local pcallStatus, pcallResult = pcall(callback)
        end
    end)
    return buttonFrame
end

function UI.CreateToggle(column, text, defaultState, callback)
    local toggleFrame = CreateInstance("Frame", {
        Name = "Toggle_" .. text:gsub("%s+", "_"),
        Size = UDim2.new(1, -10, 0, 32),
        BackgroundTransparency = 1,
        Parent = column
    })
    local toggleBg = CreateButton(UDim2.new(1, 0, 1, 0), UDim2.new(0, 0, 0, 0), CONFIG.ButtonColor, toggleFrame)
    CreateInstance("UICorner", {CornerRadius = UDim.new(0, 6), Parent = toggleBg})
    local toggleLabel = CreateTextLabel(UDim2.new(0, 120, 1, 0), UDim2.new(0, 8, 0, 0), text, CONFIG.TextColor, 11, toggleFrame)
    toggleLabel.TextXAlignment = Enum.TextXAlignment.Left
    local isOn = defaultState or false
    local switchBg = CreateInstance("Frame", {
        Name = "SwitchBg",
        Size = UDim2.new(0, 36, 0, 18),
        Position = UDim2.new(1, -44, 0.5, -9),
        BackgroundColor3 = Color3.fromRGB(40, 40, 50),
        Parent = toggleBg
    })
    CreateInstance("UICorner", {CornerRadius = UDim.new(1, 0), Parent = switchBg})
    local switchDot = CreateInstance("Frame", {
        Name = "SwitchDot",
        Size = UDim2.new(0, 14, 0, 14),
        Position = UDim2.new(0, 2, 0.5, -7),
        BackgroundColor3 = CONFIG.TextColor,
        Parent = switchBg
    })
    CreateInstance("UICorner", {CornerRadius = UDim.new(1, 0), Parent = switchDot})
    local function UpdateSwitch()
        if isOn then
            TweenObject(switchBg, {BackgroundColor3 = CONFIG.NeonPurple}, 0.2)
            TweenObject(switchDot, {Position = UDim2.new(0, 20, 0.5, -7)}, 0.2)
        else
            TweenObject(switchBg, {BackgroundColor3 = Color3.fromRGB(40, 40, 50)}, 0.2)
            TweenObject(switchDot, {Position = UDim2.new(0, 2, 0.5, -7)}, 0.2)
        end
    end
    UpdateSwitch()
    toggleBg.MouseButton1Click:Connect(function()
        isOn = not isOn
        UpdateSwitch()
        if callback then
            local pcallStatus, pcallResult = pcall(callback, isOn)
        end
    end)
    return {Frame = toggleFrame, GetState = function() return isOn end}
end

function UI.CreateSlider(column, text, minValue, maxValue, defaultValue, callback)
    local sliderFrame = CreateInstance("Frame", {
        Name = "Slider_" .. text:gsub("%s+", "_"),
        Size = UDim2.new(1, -10, 0, 44),
        BackgroundTransparency = 1,
        Parent = column
    })
    local sliderBg = CreateButton(UDim2.new(1, 0, 1, 0), UDim2.new(0, 0, 0, 0), CONFIG.ButtonColor, sliderFrame)
    CreateInstance("UICorner", {CornerRadius = UDim.new(0, 6), Parent = sliderBg})
    local sliderLabel = CreateTextLabel(UDim2.new(1, 0, 0, 12), UDim2.new(0, 8, 0, 3), text, CONFIG.TextColor, 11, sliderFrame)
    sliderLabel.TextXAlignment = Enum.TextXAlignment.Left
    local valueLabel = CreateTextLabel(UDim2.new(0, 40, 0, 14), UDim2.new(1, -48, 0, 4), tostring(defaultValue), CONFIG.NeonPurple, 11, sliderFrame)
    local trackBg = CreateInstance("Frame", {
        Name = "TrackBg",
        Size = UDim2.new(1, -24, 0, 3),
        Position = UDim2.new(0, 12, 1, -10),
        BackgroundColor3 = Color3.fromRGB(40, 40, 50),
        Parent = sliderFrame
    })
    CreateInstance("UICorner", {CornerRadius = UDim.new(1, 0), Parent = trackBg})
    local defaultValueFraction = (defaultValue - minValue) / (maxValue - minValue)
    local trackFill = CreateInstance("Frame", {
        Name = "TrackFill",
        Size = UDim2.new(defaultValueFraction, -3, 0, 3),
        Position = UDim2.new(0, 2, 0, 0),
        BackgroundColor3 = CONFIG.NeonPurple,
        Parent = trackBg
    })
    CreateInstance("UICorner", {CornerRadius = UDim.new(1, 0), Parent = trackFill})
    local trackDot = CreateInstance("Frame", {
        Name = "TrackDot",
        Size = UDim2.new(0, 12, 0, 12),
        Position = UDim2.new(defaultValueFraction, -5, 0.5, -6),
        BackgroundColor3 = CONFIG.TextColor,
        Parent = trackBg
    })
    CreateInstance("UICorner", {CornerRadius = UDim.new(1, 0), Parent = trackDot})
    local draggingSlider = false
    local currentSliderValue = defaultValue
    local function UpdateSlider(position)
        local pcallStatus, pcallResult = pcall(function()
            local relativePos = math.clamp((position - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X, 0, 1)
            local value = math.floor((minValue + (relativePos * (maxValue - minValue))) * 10) / 10
            value = math.clamp(value, minValue, maxValue)
            currentSliderValue = value
            local fillPercent = (value - minValue) / (maxValue - minValue)
            TweenObject(trackFill, {Size = UDim2.new(fillPercent, -3, 0, 3)}, 0.1)
            TweenObject(trackDot, {Position = UDim2.new(fillPercent, -5, 0.5, -6)}, 0.1)
            valueLabel.Text = tostring(math.floor(value))
            if callback then
                callback(value)
            end
        end)
    end
    trackBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            draggingSlider = true
            UpdateSlider(input.Position.X)
        end
    end)
    trackBg.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            draggingSlider = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if draggingSlider and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            UpdateSlider(input.Position.X)
        end
    end)
    return {Frame = sliderFrame, GetValue = function() return currentSliderValue end}
end

function UI.CreateDropdown(column, text, options, defaultIndex, callback)
    local dropdownFrame = CreateInstance("Frame", {
        Name = "DD_" .. text:gsub("%s+", "_"),
        Size = UDim2.new(1, -10, 0, 32),
        BackgroundTransparency = 1,
        Parent = column
    })
    local dropdownBg = CreateButton(UDim2.new(1, 0, 1, 0), UDim2.new(0, 0, 0, 0), CONFIG.ButtonColor, dropdownFrame)
    CreateInstance("UICorner", {CornerRadius = UDim.new(0, 6), Parent = dropdownBg})
    local dropdownLabel = CreateTextLabel(UDim2.new(0, 80, 1, 0), UDim2.new(0, 8, 0, 0), text, CONFIG.TextColor, 11, dropdownFrame)
    dropdownLabel.TextXAlignment = Enum.TextXAlignment.Left
    local currentValue = options[defaultIndex or 1] or "Select"
    local valueLabel = CreateTextLabel(UDim2.new(1, -60, 1, 0), UDim2.new(0, 85, 0, 0), currentValue, CONFIG.NeonPurple, 11, dropdownFrame)
    local arrowLabel = CreateTextLabel(UDim2.new(0, 20, 1, 0), UDim2.new(1, -22, 0, 0), "▼", CONFIG.TextColor, 10, dropdownFrame)
    local menuContainer = CreateInstance("Frame", {
        Name = "MenuContainer",
        Size = UDim2.new(1, 0, 0, 0),
        Position = UDim2.new(0, 0, 1, 0),
        BackgroundColor3 = CONFIG.ButtonColor,
        Visible = false,
        ZIndex = 10,
        ClipsDescendants = true,
        Parent = dropdownBg
    })
    CreateInstance("UICorner", {CornerRadius = UDim.new(0, 6), Parent = menuContainer})
    CreateUIStroke(CONFIG.NeonPurple, 1, 0.5).Parent = menuContainer
    local menuScroll = CreateInstance("ScrollingFrame", {
        Name = "MenuScroll",
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        ScrollBarThickness = 4,
        ScrollBarImageColor3 = CONFIG.NeonPurple,
        Parent = menuContainer
    })
    CreateInstance("UIListLayout", {Padding = UDim.new(0, 2), Parent = menuScroll})
    CreateInstance("UIPadding", {PaddingLeft = UDim.new(0, 2), PaddingRight = UDim.new(0, 2), Parent = menuScroll})
    local isOpen = false
    local function UpdateMenuHeight()
        local optionCount = #options
        local height = math.min(optionCount * 26, 120)
        menuContainer.Size = UDim2.new(1, 0, 0, height)
        menuScroll.CanvasSize = UDim2.new(0, 0, 0, optionCount * 28)
    end
    for idx, optionText in ipairs(options) do
        local optionBtn = CreateButton(UDim2.new(1, 0, 0, 24), UDim2.new(0, 0, 0, 0), Color3.fromRGB(25, 25, 35), menuScroll)
        CreateInstance("UICorner", {CornerRadius = UDim.new(0, 4), Parent = optionBtn})
        CreateTextLabel(UDim2.new(1, 0, 1, 0), UDim2.new(0, 0, 0, 0), optionText, CONFIG.TextColor, 10, optionBtn)
        optionBtn.MouseButton1Click:Connect(function()
            currentValue = optionText
            valueLabel.Text = currentValue
            arrowLabel.Text = "▼"
            menuContainer.Visible = false
            isOpen = false
            if callback then
                local pcallStatus, pcallResult = pcall(callback, idx, optionText)
            end
        end)
    end
    UpdateMenuHeight()
    dropdownBg.MouseButton1Click:Connect(function()
        isOpen = not isOpen
        menuContainer.Visible = isOpen
        arrowLabel.Text = isOpen and "▲" or "▼"
    end)
    return {Frame = dropdownFrame, GetValue = function() return currentValue end, GetIndex = function() for i, v in ipairs(options) do if v == currentValue then return i end end return 1 end}
end

function UI.CreateLabel(column, text, textColor)
    local labelFrame = CreateInstance("Frame", {
        Name = "Lbl_" .. text:gsub("%s+", "_"),
        Size = UDim2.new(1, -10, 0, 22),
        BackgroundTransparency = 1,
        Parent = column
    })
    CreateTextLabel(UDim2.new(1, 0, 1, 0), UDim2.new(0, 4, 0, 0), text, textColor or CONFIG.SecondaryText, 11, labelFrame)
    return labelFrame
end

function UI.CreateSection(column, title)
    local sectionFrame = CreateInstance("Frame", {
        Name = "Sec_" .. title:gsub("%s+", "_"),
        Size = UDim2.new(1, -10, 0, 24),
        BackgroundTransparency = 1,
        Parent = column
    })
    local sectionBg = CreateButton(UDim2.new(1, 0, 1, 0), UDim2.new(0, 0, 0, 0), Color3.fromRGB(15, 15, 25), sectionFrame)
    CreateInstance("UICorner", {CornerRadius = UDim.new(0, 4), Parent = sectionBg})
    CreateUIStroke(CONFIG.NeonPurple, 1, 0.5).Parent = sectionBg
    CreateTextLabel(UDim2.new(1, 0, 1, 0), UDim2.new(0, 0, 0, 0), "▸ " .. title, CONFIG.NeonPurple, 11, sectionBg)
    return sectionFrame
end

-- ═══════════════════════════════════════════════════════════════════════
-- HELPER: Create TextBox Input
-- ═══════════════════════════════════════════════════════════════════════

function UI.CreateTextBox(column, labelText, placeholder, defaultValue, callback)
    local boxFrame = CreateInstance("Frame", {
        Name = "TB_" .. labelText:gsub("%s+", "_"),
        Size = UDim2.new(1, -10, 0, 40),
        BackgroundTransparency = 1,
        Parent = column
    })
    local label = CreateTextLabel(UDim2.new(1, 0, 0, 14), UDim2.new(0, 4, 0, 0), labelText, CONFIG.SecondaryText, 10, boxFrame)
    label.TextXAlignment = Enum.TextXAlignment.Left
    local inputBg = CreateInstance("Frame", {
        Name = "InputBg",
        Size = UDim2.new(1, 0, 0, 22),
        Position = UDim2.new(0, 0, 1, -22),
        BackgroundColor3 = CONFIG.ButtonColor,
        Parent = boxFrame
    })
    CreateInstance("UICorner", {CornerRadius = UDim.new(0, 4), Parent = inputBg})
    CreateUIStroke(CONFIG.NeonPurple, 1, 0.6).Parent = inputBg
    local textBox = CreateInstance("TextBox", {
        Name = "TextBox",
        Size = UDim2.new(1, -8, 1, 0),
        Position = UDim2.new(0, 4, 0, 0),
        BackgroundTransparency = 1,
        Text = tostring(defaultValue or ""),
        PlaceholderText = placeholder or "Enter value...",
        TextColor3 = CONFIG.TextColor,
        TextSize = 12,
        Font = Enum.Font.Gotham,
        ClearTextOnFocus = false,
        Parent = inputBg
    })
    textBox.FocusLost:Connect(function(enterPressed)
        if enterPressed then
            local enteredValue = tonumber(textBox.Text)
            if enteredValue then
                if callback then
                    local pcallStatus, pcallResult = pcall(callback, enteredValue)
                end
            else
                textBox.Text = tostring(defaultValue or "")
            end
        end
    end)
    return {Frame = boxFrame, GetValue = function() return tonumber(textBox.Text) or defaultValue end, SetValue = function(v) textBox.Text = tostring(v) end}
end

